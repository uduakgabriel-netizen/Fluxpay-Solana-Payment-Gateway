# Database
DATABASE_URL="postgresql://user:password@localhost:5432/fluxpay"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Solana
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
SOLANA_RPC_DEVNET="https://api.devnet.solana.com"
SOLANA_NETWORK="devnet"  # or "mainnet" for production

# FluxPay Main Wallet (for swaps and settlements)
FLUXPAY_WALLET_PRIVATE_KEY="your-encrypted-private-key"
FLUXPAY_WALLET_PUBLIC_KEY="your-public-key"

# Helius (Real-time Solana transaction detection)
HELIUS_API_KEY="your-helius-api-key"
HELIUS_WEBHOOK_ID="your-webhook-id"

# Jupiter (Token swap aggregator)
JUPITER_API_URL="https://quote-api.jup.ag/v6"

# Encryption (32 bytes in hex = 64 hex chars for AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your-64-char-hex-encryption-key"

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
