# Database
DATABASE_URL="postgresql://postgres:uduak%4012@localhost:5432/fluxpay"

# JWT
JWT_SECRET="fluxpay-super-secret-jwt-key-change-this-in-production-2026"
JWT_EXPIRES_IN="7d"

# Solana
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
SOLANA_RPC_DEVNET="https://api.devnet.solana.com"
SOLANA_NETWORK="devnet"

# FluxPay Main Wallet (for swaps and settlements)
FLUXPAY_WALLET_PRIVATE_KEY="your-encrypted-private-key"
FLUXPAY_WALLET_PUBLIC_KEY="your-public-key"

# Helius
HELIUS_API_KEY="your-zhelius-api-key"
HELIUS_WEBHOOK_ID="your-webhook-id"

# Jupiter
JUPITER_API_URL="https://quote-api.jup.ag/v6"

# Encryption (32 bytes hex = 64 hex chars for AES-256)
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
