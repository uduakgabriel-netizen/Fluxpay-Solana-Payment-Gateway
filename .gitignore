# ─── Dependencies ───
node_modules/
/.pnp
.pnp.js

# ─── Build Output (Next.js, TS, etc.) ───
.next/
/out/
build/
dist/

# ─── Environment files (dotenvx) ───
# We use dotenvx for encryption, so it is safer to commit encrypted .env files
# NEVER COMMIT .env.keys!
.env.keys
.env.local
.env.development.local
.env.test.local
.env.production.local

# ─── Logs & Temp Files ───
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
test_output*.txt
.antigravityignore

# ─── Prisma Database (SQLite local data if applicable) ───
*.db
*.db-journal

# ─── Testing & Coverage ───
coverage/
.nyc_output

# ─── OS files ───
.DS_Store
Thumbs.db
desktop.ini

# ─── TypeScript & Lint cache ───
*.tsbuildinfo
.eslintcache

# ─── IDE / Editor ───
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
