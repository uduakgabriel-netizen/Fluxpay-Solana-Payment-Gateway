logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
test_output*.txt
.antigravityignore

# ─── Prisma Database (SQLite local data if applicable) ───
*.db
*.db-journal

# ─── OS files & Testing ───
.DS_Store
Thumbs.db
desktop.ini
coverage/

# ─── TypeScript cache ───
*.tsbuildinfo
.eslintcache

